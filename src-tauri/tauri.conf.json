{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Machine Status Display",
  "version": "0.1.1",
  "identifier": "com.joel.machine-status-display",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Machine Status Display",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "fullscreen": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxMkI4NzZFODRDMzY1QQpSV1JhTmt6b2RyZ1NDNDUrMWF3YldKbXJpcjhxUWkyUnJHK3NLZm4wKzJRY0RGeEpoMmJOTmNxZgo=",
      "endpoints": [
        "https://github.com/joe2824/machine_status_display/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
